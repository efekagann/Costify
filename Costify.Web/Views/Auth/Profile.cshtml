@{
    ViewData["Title"] = Localizer["Profile_Title"].Value;
}

<div class="page-header">
    <div class="text-muted small"><i class="bi bi-person-circle me-1"></i>@ViewBag.Username</div>
</div>

<div class="row g-4">
    <!-- Bilgi Güncelleme -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-person me-2"></i>@Localizer["Profile_UpdateInfo"]
            </div>
            <div class="card-body">
                <form asp-action="UpdateProfile" asp-controller="Auth" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Register_DisplayName"]</label>
                        <input type="text" name="displayName" class="form-control"
                               value="@ViewBag.DisplayName" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Common_Email"]</label>
                        <input type="email" name="email" class="form-control"
                               value="@ViewBag.Email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Register_Username"]</label>
                        <input type="text" class="form-control" value="@ViewBag.Username" disabled />
                        <div class="form-text">@Localizer["Login_Username"] değiştirilemez.</div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>@Localizer["Common_Update"]
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Şifre Değiştir -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-lock me-2"></i>@Localizer["Profile_ChangePassword"]
            </div>
            <div class="card-body">
                <form asp-action="ChangePassword" asp-controller="Auth" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Profile_CurrentPassword"]</label>
                        <input type="password" name="currentPassword" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Profile_NewPassword"]</label>
                        <input type="password" name="newPassword" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Profile_ConfirmPassword"]</label>
                        <input type="password" name="confirmPassword" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-key me-1"></i>@Localizer["Profile_ChangePassword"]
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
