@{
    Layout = null;
    ViewData["Title"] = "Giriş Yap";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Costify — Giriş</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root { --primary: #4f46e5; --primary-dark: #4338ca; }

        body {
            background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #1e1b4b 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .login-card {
            background: white;
            border-radius: 1.25rem;
            padding: 2.5rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 25px 50px rgba(0,0,0,.35);
        }

        .brand-icon {
            width: 56px; height: 56px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem; color: white;
            box-shadow: 0 8px 20px rgba(79,70,229,.35);
        }

        .form-control {
            border: 1.5px solid #e2e8f0;
            border-radius: 0.625rem;
            padding: .65rem 1rem;
            transition: border-color .2s, box-shadow .2s;
        }
        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(79,70,229,.15);
        }

        .input-group-text {
            border: 1.5px solid #e2e8f0;
            background: #f8fafc;
            border-radius: 0.625rem 0 0 0.625rem;
            color: #94a3b8;
        }
        .input-group .form-control { border-radius: 0 0.625rem 0.625rem 0; border-left: none; }
        .input-group:focus-within .input-group-text { border-color: var(--primary); }

        .btn-login {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none;
            border-radius: 0.625rem;
            padding: .7rem;
            font-weight: 600;
            letter-spacing: .02em;
            transition: opacity .2s, transform .1s;
            box-shadow: 0 4px 12px rgba(79,70,229,.35);
        }
        .btn-login:hover { opacity: .92; transform: translateY(-1px); }
        .btn-login:active { transform: translateY(0); }

        .dots {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            pointer-events: none; overflow: hidden; z-index: 0;
        }
        .dot {
            position: absolute; border-radius: 50%;
            background: rgba(255,255,255,.05);
            animation: float 8s ease-in-out infinite;
        }
        @@keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(180deg); }
        }
    </style>
</head>
<body>
    <div class="dots">
        <div class="dot" style="width:120px;height:120px;top:10%;left:5%;animation-delay:0s"></div>
        <div class="dot" style="width:80px;height:80px;top:60%;left:80%;animation-delay:2s"></div>
        <div class="dot" style="width:60px;height:60px;top:80%;left:15%;animation-delay:4s"></div>
        <div class="dot" style="width:160px;height:160px;top:20%;left:70%;animation-delay:1s"></div>
    </div>

    <div class="login-card position-relative" style="z-index:1">
        <div class="text-center mb-4">
            <div class="brand-icon mx-auto mb-3" style="background:none;box-shadow:none;width:160px;height:160px">
                <img src="/images/logo.png" alt="Costify" style="width:160px;height:160px;object-fit:contain" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <span style="display:none;width:250px;height:160px;background:linear-gradient(135deg,#4f46e5,#4338ca);border-radius:28px;align-items:center;justify-content:center;font-size:3.5rem;color:white">
                    <i class="bi bi-box-seam"></i>
                </span>
            </div>
            <h4 class="fw-bold mb-1" style="color:#1e293b">Costify</h4>
            <p class="text-muted small mb-0">Kafe & Restoran Maliyet Yönetimi</p>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.Error as string))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 rounded-3 py-2 px-3 mb-3" style="font-size:.875rem">
                <i class="bi bi-exclamation-circle-fill"></i>
                @ViewBag.Error
            </div>
        }

        <form asp-action="Login" asp-controller="Auth" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div class="mb-3">
                <label class="form-label fw-medium small" style="color:#374151">Kullanıcı Adı</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input type="text" name="username" class="form-control" placeholder="admin"
                           autocomplete="username" required autofocus />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-medium small" style="color:#374151">Şifre</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input type="password" name="password" id="passwordInput" class="form-control"
                           placeholder="••••••••" autocomplete="current-password" required />
                    <button type="button" class="btn btn-outline-secondary border-start-0"
                            style="border:1.5px solid #e2e8f0;border-radius:0 0.625rem 0.625rem 0"
                            onclick="togglePass()">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn btn-login btn-primary w-100 text-white">
                <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
            </button>
        </form>

        <div class="text-center mt-4 pt-3 border-top">
            <span class="text-muted" style="font-size:.75rem">
                <i class="bi bi-shield-check me-1" style="color:#10b981"></i>
                Güvenli bağlantı — yalnızca yetkili erişim
            </span>
        </div>
    </div>

    <script>
    function togglePass() {
        const input = document.getElementById('passwordInput');
        const icon = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            input.type = 'password';
            icon.className = 'bi bi-eye';
        }
    }
    </script>
</body>
</html>
