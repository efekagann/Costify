@using Costify.Web.ViewModels
@model IPaginatedResult

@if (Model.TotalCount == 0) { return; }

@{
    // Rebuild query string, replacing or removing "page"
    var existing = Context.Request.Query
        .Where(kv => kv.Key != "page")
        .Select(kv => $"{Uri.EscapeDataString(kv.Key)}={Uri.EscapeDataString(kv.Value.ToString())}");
    var qs = string.Join("&", existing);
    var baseUrl = Context.Request.Path + (qs.Length > 0 ? "?" + qs + "&" : "?");

    var from = (Model.PageIndex - 1) * Model.PageSize + 1;
    var to   = Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount);

    int startPage = Math.Max(1, Model.PageIndex - 2);
    int endPage   = Math.Min(Model.TotalPages, Model.PageIndex + 2);
}

<div class="d-flex justify-content-between align-items-center mt-3 px-1" style="font-size:.8rem">
    <span class="text-muted">
        @from–@to / @Model.TotalCount @Localizer["Pagination_Items"]
    </span>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="pagination">
            <ul class="pagination pagination-sm mb-0 gap-1" style="--bs-pagination-border-radius:.5rem">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" href="@(baseUrl)page=@(Model.PageIndex - 1)" aria-label="Previous">‹</a>
                </li>

                @if (startPage > 1)
                {
                    <li class="page-item"><a class="page-link" href="@(baseUrl)page=1">1</a></li>
                    @if (startPage > 2) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" href="@(baseUrl)page=@i">@i</a>
                    </li>
                }

                @if (endPage < Model.TotalPages)
                {
                    @if (endPage < Model.TotalPages - 1) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                    <li class="page-item"><a class="page-link" href="@(baseUrl)page=@Model.TotalPages">@Model.TotalPages</a></li>
                }

                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" href="@(baseUrl)page=@(Model.PageIndex + 1)" aria-label="Next">›</a>
                </li>
            </ul>
        </nav>
    }
</div>
