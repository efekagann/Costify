@model Costify.Domain.Entities.PurchaseOrder
@{
    ViewData["Title"] = Model.OrderNumber;
    var (badgeClass, statusLabel) = Model.Status switch {
        Costify.Domain.Enums.OrderStatus.Received => ("success", "Teslim Alındı"),
        Costify.Domain.Enums.OrderStatus.Ordered => ("primary", "Sipariş Verildi"),
        Costify.Domain.Enums.OrderStatus.Cancelled => ("danger", "İptal"),
        Costify.Domain.Enums.OrderStatus.PartiallyReceived => ("warning text-dark", "Kısmi Teslim"),
        _ => ("secondary", "Taslak")
    };
}

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">Sipariş Bilgileri</div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">Sipariş No</dt>
                    <dd class="col-7 fw-semibold">@Model.OrderNumber</dd>

                    <dt class="col-5 text-muted">Tedarikçi</dt>
                    <dd class="col-7">@Model.Vendor?.Name</dd>

                    <dt class="col-5 text-muted">Sipariş Tarihi</dt>
                    <dd class="col-7">@Model.OrderDate.ToString("dd.MM.yyyy")</dd>

                    @if (Model.DeliveryDate.HasValue)
                    {
                        <dt class="col-5 text-muted">Teslim Tarihi</dt>
                        <dd class="col-7">@Model.DeliveryDate.Value.ToString("dd.MM.yyyy")</dd>
                    }

                    <dt class="col-5 text-muted">Durum</dt>
                    <dd class="col-7"><span class="badge bg-@badgeClass">@statusLabel</span></dd>

                    <dt class="col-5 text-muted">Toplam Tutar</dt>
                    <dd class="col-7 fs-5 fw-bold">@Model.TotalAmount.ToString("N2") ₺</dd>
                </dl>

                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="mt-3 p-2 bg-light rounded small text-muted">
                        <i class="bi bi-chat-text me-1"></i>@Model.Notes
                    </div>
                }
            </div>
            <div class="card-footer d-flex gap-2">
                @if (Model.Status == Costify.Domain.Enums.OrderStatus.Ordered ||
                     Model.Status == Costify.Domain.Enums.OrderStatus.PartiallyReceived)
                {
                    <form asp-action="Receive" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Sipariş teslim alındı olarak işaretlenecek ve stoklar güncellenecek. Onaylıyor musunuz?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-success">
                            <i class="bi bi-check2-circle me-1"></i>Teslim Al
                        </button>
                    </form>
                }
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Geri</a>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">Sipariş Kalemleri</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ürün</th>
                            <th class="text-end">Miktar</th>
                            <th class="text-end">Birim Fiyat</th>
                            <th class="text-end">Toplam</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Product?.Name</td>
                                <td class="text-end">
                                    @item.Quantity.ToString("N4")
                                    <small class="text-muted">@item.Product?.Unit?.Symbol</small>
                                </td>
                                <td class="text-end">@item.UnitPrice.ToString("N2") ₺</td>
                                <td class="text-end fw-semibold">@item.TotalPrice.ToString("N2") ₺</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Genel Toplam</td>
                            <td class="text-end fw-bold fs-5">@Model.TotalAmount.ToString("N2") ₺</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
