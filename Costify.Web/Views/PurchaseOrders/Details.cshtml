@model Costify.Domain.Entities.PurchaseOrder
@{
    ViewData["Title"] = Model.OrderNumber;
    var (badgeClass, statusLabel) = Model.Status switch {
        Costify.Domain.Enums.OrderStatus.Received          => ("success",             Localizer["Common_Received"].Value),
        Costify.Domain.Enums.OrderStatus.Ordered           => ("primary",             Localizer["Common_Ordered"].Value),
        Costify.Domain.Enums.OrderStatus.Cancelled         => ("danger",              Localizer["Common_Cancelled"].Value),
        Costify.Domain.Enums.OrderStatus.PartiallyReceived => ("warning text-dark",   Localizer["Common_PartiallyReceived"].Value),
        _                                                  => ("secondary",           Localizer["Common_Draft"].Value)
    };
}

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">@Localizer["PO_Info"]</div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">@Localizer["Common_OrderNo"]</dt>
                    <dd class="col-7 fw-semibold">@Model.OrderNumber</dd>

                    <dt class="col-5 text-muted">@Localizer["Common_Vendor"]</dt>
                    <dd class="col-7">@Model.Vendor?.Name</dd>

                    <dt class="col-5 text-muted">@Localizer["PO_OrderDate"]</dt>
                    <dd class="col-7">@Model.OrderDate.ToString("dd.MM.yyyy")</dd>

                    @if (Model.DeliveryDate.HasValue)
                    {
                        <dt class="col-5 text-muted">@Localizer["PO_DeliveryDate"]</dt>
                        <dd class="col-7">@Model.DeliveryDate.Value.ToString("dd.MM.yyyy")</dd>
                    }

                    <dt class="col-5 text-muted">@Localizer["Common_Status"]</dt>
                    <dd class="col-7"><span class="badge bg-@badgeClass">@statusLabel</span></dd>

                    <dt class="col-5 text-muted">@Localizer["PO_TotalAmount"]</dt>
                    <dd class="col-7 fs-5 fw-bold">@Model.TotalAmount.ToString("N2") ₺</dd>
                </dl>

                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="mt-3 p-2 bg-light rounded small text-muted">
                        <i class="bi bi-chat-text me-1"></i>@Model.Notes
                    </div>
                }
            </div>
            <div class="card-footer d-flex gap-2">
                @if (Model.Status == Costify.Domain.Enums.OrderStatus.Ordered ||
                     Model.Status == Costify.Domain.Enums.OrderStatus.PartiallyReceived)
                {
                    <form asp-action="Receive" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('@Html.Raw(Localizer["PO_ReceiveConfirm"].Value.Replace("'", "\\'"))')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-success">
                            <i class="bi bi-check2-circle me-1"></i>@Localizer["PO_Receive"]
                        </button>
                    </form>
                }
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">@Localizer["Common_Back"]</a>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">@Localizer["PO_OrderItems"]</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>@Localizer["Common_Product"]</th>
                            <th class="text-end">@Localizer["Common_Quantity"]</th>
                            <th class="text-end">@Localizer["Common_UnitPrice"]</th>
                            <th class="text-end">@Localizer["Common_Total"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Product?.Name</td>
                                <td class="text-end">
                                    @item.Quantity.ToString("N4")
                                    <small class="text-muted">@item.Product?.Unit?.Symbol</small>
                                </td>
                                <td class="text-end">@item.UnitPrice.ToString("N2") ₺</td>
                                <td class="text-end fw-semibold">@item.TotalPrice.ToString("N2") ₺</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold">@Localizer["Common_GrandTotal"]</td>
                            <td class="text-end fw-bold fs-5">@Model.TotalAmount.ToString("N2") ₺</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
