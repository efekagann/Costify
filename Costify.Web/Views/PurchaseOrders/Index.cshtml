@model IEnumerable<Costify.Domain.Entities.PurchaseOrder>
@{
    ViewData["Title"] = Localizer["PO_Title"].Value;
}

<div class="page-header">
    <div class="text-muted" style="font-size:.875rem">
        <i class="bi bi-cart-check me-1"></i>@Model.Count() @Localizer["PO_Count"]
    </div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#orderModal">
        <i class="bi bi-plus-lg me-1"></i>@Localizer["PO_NewOrder"]
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>@Localizer["Common_OrderNo"]</th>
                    <th>@Localizer["Common_Vendor"]</th>
                    <th>@Localizer["PO_OrderDate"]</th>
                    <th class="text-center">@Localizer["PO_Items"]</th>
                    <th class="text-end">@Localizer["Common_Total"]</th>
                    <th>@Localizer["Common_Status"]</th>
                    <th style="width:50px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    var (cls, lbl, icon) = o.Status switch {
                        Costify.Domain.Enums.OrderStatus.Received          => ("bg-success-soft", Localizer["Common_Received"].Value,          "bi-check-circle-fill"),
                        Costify.Domain.Enums.OrderStatus.Ordered           => ("bg-info-soft",    Localizer["Common_Ordered"].Value,            "bi-clock"),
                        Costify.Domain.Enums.OrderStatus.Cancelled         => ("bg-danger-soft",  Localizer["Common_Cancelled"].Value,          "bi-x-circle"),
                        Costify.Domain.Enums.OrderStatus.PartiallyReceived => ("bg-warning-soft", Localizer["Common_PartiallyReceived"].Value,   "bi-half"),
                        _                                                  => ("bg-secondary-soft",Localizer["Common_Draft"].Value,              "bi-pencil")
                    };
                    <tr>
                        <td>
                            <a asp-action="Details" asp-route-id="@o.Id" class="fw-semibold">@o.OrderNumber</a>
                        </td>
                        <td>@o.Vendor?.Name</td>
                        <td class="text-muted" style="font-size:.85rem">@o.OrderDate.ToString("dd.MM.yyyy")</td>
                        <td class="text-center text-muted" style="font-size:.85rem">@o.Items.Count</td>
                        <td class="text-end fw-semibold">@o.TotalAmount.ToString("N2") ₺</td>
                        <td><span class="badge @cls"><i class="bi @icon me-1"></i>@lbl</span></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@o.Id"
                               class="btn btn-sm btn-outline-secondary" title="@Localizer["Common_Detail"]">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="bi bi-cart"></i>
                                <div class="fw-medium">@Localizer["PO_NoOrders"]</div>
                                <small>@Localizer["PO_CreateFirst"]</small>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- New Order Modal -->
<div class="modal fade" id="orderModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <form asp-action="Create" method="post" id="orderForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-cart-plus me-2"></i>@Localizer["PO_NewPurchaseOrder"]</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3 mb-4 pb-3" style="border-bottom:1px solid var(--border)">
                        <div class="col-md-5">
                            <label class="form-label">@Localizer["Common_Vendor"] <span class="text-danger">*</span></label>
                            <select name="VendorId" class="form-select" required>
                                <option value="">@Localizer["PO_SelectVendor"]</option>
                                @foreach (SelectListItem v in ViewBag.Vendors)
                                {
                                    <option value="@v.Value">@v.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["PO_OrderDate"] <span class="text-danger">*</span></label>
                            <input type="date" name="OrderDate" class="form-control"
                                   value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">@Localizer["PO_ExpectedDelivery"]</label>
                            <input type="date" name="DeliveryDate" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">@Localizer["Common_Note"]</label>
                            <input type="text" name="Notes" class="form-control" placeholder="@Localizer["PO_NoteOptional"]" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fw-semibold" style="font-size:.875rem">
                            <i class="bi bi-list-ul me-1"></i>@Localizer["PO_OrderItems"]
                        </span>
                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="addOrderRow()">
                            <i class="bi bi-plus-circle me-1"></i>@Localizer["PO_AddProduct"]
                        </button>
                    </div>

                    <table class="table table-sm" id="itemsTable">
                        <thead>
                            <tr style="background:#f8fafc">
                                <th style="min-width:220px">@Localizer["Common_Product"]</th>
                                <th style="width:140px">@Localizer["Common_Quantity"]</th>
                                <th style="width:160px">@Localizer["PO_UnitPriceLabel"]</th>
                                <th style="width:120px" class="text-end">@Localizer["Common_Total"]</th>
                                <th style="width:40px"></th>
                            </tr>
                        </thead>
                        <tbody id="itemsBody">
                            <tr id="emptyRow">
                                <td colspan="5" class="text-center py-3 text-muted" style="font-size:.85rem">
                                    <i class="bi bi-arrow-up me-1"></i>@Localizer["PO_AddProductHint"]
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end fw-bold" style="font-size:.9rem">@Localizer["PO_GrandTotalLabel"]</td>
                                <td class="text-end fw-bold" id="grandTotal" style="font-size:1rem;color:var(--primary)">0,00 ₺</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@Localizer["Common_Cancel"]</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>@Localizer["PO_CreateOrder"]
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
const allProducts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    (ViewBag.Products as IEnumerable<Costify.Domain.Entities.Product> ?? [])
        .Select(p => new { p.Id, p.Name, unit = p.Unit != null ? p.Unit.Symbol : "", lastPrice = p.LastPurchasePrice })
));

const i18n = {
    selectProduct: '@Html.Raw(Localizer["PO_SelectProduct"].Value.Replace("'", "\\'"))',
    addProductHint: '@Html.Raw(Localizer["PO_AddProductHint"].Value.Replace("'", "\\'"))'
};

let rowIdx = 0;

function addOrderRow() {
    document.getElementById('emptyRow')?.remove();
    const tbody = document.getElementById('itemsBody');
    const i = rowIdx++;
    const opts = allProducts.map(p =>
        `<option value="${p.Id}" data-price="${p.lastPrice}" data-unit="${p.unit}">${p.Name} (${p.unit})</option>`
    ).join('');

    const tr = document.createElement('tr');
    tr.id = `row_${i}`;
    tr.innerHTML = `
        <td>
            <select name="productIds" class="form-select form-select-sm" required
                    onchange="onProductChange(this,${i})">
                <option value="">${i18n.selectProduct}</option>${opts}
            </select>
        </td>
        <td>
            <div class="input-group input-group-sm">
                <input type="number" name="quantities" id="qty_${i}" class="form-control"
                       step="0.01" min="0.01" value="1" required oninput="calcRow(${i})" />
                <span class="input-group-text" id="unit_${i}" style="min-width:36px"></span>
            </div>
        </td>
        <td>
            <div class="input-group input-group-sm">
                <input type="number" name="unitPrices" id="price_${i}" class="form-control"
                       step="0.01" min="0" value="0" required oninput="calcRow(${i})" />
                <span class="input-group-text">₺</span>
            </div>
        </td>
        <td class="text-end fw-semibold" id="total_${i}" style="font-size:.85rem">0,00 ₺</td>
        <td>
            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeRow(${i})">
                <i class="bi bi-trash"></i>
            </button>
        </td>`;
    tbody.appendChild(tr);
}

function onProductChange(sel, i) {
    const opt = sel.options[sel.selectedIndex];
    document.getElementById(`price_${i}`).value = opt.dataset.price || '0';
    document.getElementById(`unit_${i}`).textContent = opt.dataset.unit || '';
    calcRow(i);
}

function calcRow(i) {
    const qty   = parseFloat(document.getElementById(`qty_${i}`)?.value)   || 0;
    const price = parseFloat(document.getElementById(`price_${i}`)?.value) || 0;
    document.getElementById(`total_${i}`).textContent =
        (qty * price).toLocaleString('tr-TR', {minimumFractionDigits:2}) + ' ₺';
    calcGrandTotal();
}

function calcGrandTotal() {
    let gt = 0;
    document.querySelectorAll('[id^="total_"]').forEach(el => {
        gt += parseFloat(el.textContent.replace(/[^\d,]/g,'').replace(',','.')) || 0;
    });
    document.getElementById('grandTotal').textContent =
        gt.toLocaleString('tr-TR', {minimumFractionDigits:2}) + ' ₺';
}

function removeRow(i) {
    document.getElementById(`row_${i}`)?.remove();
    calcGrandTotal();
    if (!document.querySelector('#itemsBody tr:not(#emptyRow)')) {
        const empty = document.createElement('tr');
        empty.id = 'emptyRow';
        empty.innerHTML = `<td colspan="5" class="text-center py-3 text-muted" style="font-size:.85rem"><i class="bi bi-arrow-up me-1"></i>${i18n.addProductHint}</td>`;
        document.getElementById('itemsBody').appendChild(empty);
    }
}

document.getElementById('orderModal').addEventListener('hidden.bs.modal', function() {
    document.getElementById('orderForm').reset();
    const tbody = document.getElementById('itemsBody');
    tbody.innerHTML = `<tr id="emptyRow"><td colspan="5" class="text-center py-3 text-muted" style="font-size:.85rem"><i class="bi bi-arrow-up me-1"></i>${i18n.addProductHint}</td></tr>`;
    document.getElementById('grandTotal').textContent = '0,00 ₺';
    rowIdx = 0;
});
</script>
}
