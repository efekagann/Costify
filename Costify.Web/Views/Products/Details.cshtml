@model Costify.Domain.Entities.Product
@{
    ViewData["Title"] = Model.Name;
}

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">@Localizer["Products_ProductInfo"]</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5 text-muted small">SKU</dt>
                    <dd class="col-7">@(Model.SKU ?? "—")</dd>

                    <dt class="col-5 text-muted small">@Localizer["Common_Category"]</dt>
                    <dd class="col-7">@Model.Category?.Name</dd>

                    <dt class="col-5 text-muted small">@Localizer["Common_Unit"]</dt>
                    <dd class="col-7">@Model.Unit?.Name (@Model.Unit?.Symbol)</dd>

                    <dt class="col-5 text-muted small">@Localizer["Products_CurrentStock"]</dt>
                    <dd class="col-7 @(Model.CurrentStock <= Model.MinimumStock ? "text-danger fw-bold" : "")">
                        @Model.CurrentStock.ToString("N2") @Model.Unit?.Symbol
                    </dd>

                    <dt class="col-5 text-muted small">@Localizer["Products_MinStock"]</dt>
                    <dd class="col-7">@Model.MinimumStock.ToString("N2") @Model.Unit?.Symbol</dd>

                    <dt class="col-5 text-muted small">@Localizer["Products_LastPrice"]</dt>
                    <dd class="col-7">@Model.LastPurchasePrice.ToString("N2") ₺</dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil me-1"></i>@Localizer["Common_Edit"]
                </a>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">@Localizer["Common_Back"]</a>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">@Localizer["Products_StockMovements"]</div>
            <div class="card-body p-0">
                @if (!Model.StockTransactions.Any())
                {
                    <div class="text-center py-4 text-muted"><i class="bi bi-inbox fs-3 d-block"></i>@Localizer["Products_NoMovements"]</div>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>@Localizer["Common_Date"]</th>
                                <th>@Localizer["Products_Type"]</th>
                                <th class="text-end">@Localizer["Common_Quantity"]</th>
                                <th class="text-end">@Localizer["Products_UnitCost"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.StockTransactions)
                            {
                                var typeLabel = t.Type switch {
                                    Costify.Domain.Enums.StockTransactionType.Purchase   => ("bi-arrow-down-circle-fill text-success", Localizer["Products_Purchase"].Value),
                                    Costify.Domain.Enums.StockTransactionType.Usage      => ("bi-arrow-up-circle-fill text-danger",   Localizer["Products_Usage"].Value),
                                    Costify.Domain.Enums.StockTransactionType.Waste      => ("bi-x-circle-fill text-warning",          Localizer["Products_Waste"].Value),
                                    Costify.Domain.Enums.StockTransactionType.Adjustment => ("bi-sliders text-info",                   Localizer["Products_Adjustment"].Value),
                                    _                                                    => ("bi-arrow-repeat text-secondary",          Localizer["Products_Return"].Value)
                                };
                                <tr>
                                    <td class="small">@t.TransactionDate.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td><i class="bi @typeLabel.Item1 me-1"></i>@typeLabel.Item2</td>
                                    <td class="text-end">@t.Quantity.ToString("N4")</td>
                                    <td class="text-end">@t.UnitCost.ToString("N2") ₺</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
