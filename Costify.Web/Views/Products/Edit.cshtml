@model Costify.Web.ViewModels.ProductViewModel
@{
    ViewData["Title"] = "Ürün Düzenle";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-pencil-square me-1"></i>Ürün Düzenle — @Model.Name
            </div>
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="SKU" class="form-label"></label>
                            <input asp-for="SKU" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label"></label>
                            <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select"></select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="UnitId" class="form-label"></label>
                            <select asp-for="UnitId" asp-items="Model.Units" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MinimumStock" class="form-label"></label>
                            <input asp-for="MinimumStock" class="form-control" type="number" step="0.01" min="0" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="LastPurchasePrice" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="LastPurchasePrice" class="form-control" type="number" step="0.01" min="0" />
                                <span class="input-group-text">₺</span>
                            </div>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label">Aktif</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Güncelle</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
