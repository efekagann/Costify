@{
    ViewData["Title"] = "Tanımlar";
    var categories = ViewBag.Categories as IEnumerable<Costify.Domain.Entities.Category> ?? [];
    var units = ViewBag.Units as IEnumerable<Costify.Domain.Entities.Unit> ?? [];
    var activeTab = ViewBag.ActiveTab as string ?? "categories";
}

<div class="page-header">
    <div class="text-muted" style="font-size:.875rem">
        <i class="bi bi-sliders me-1"></i>Kategori ve birim tanımları
    </div>
</div>

<!-- Sekmeler -->
<ul class="nav nav-tabs mb-3" id="defTabs" role="tablist">
    <li class="nav-item">
        <button class="nav-link @(activeTab=="categories"?"active":"")"
                data-bs-toggle="tab" data-bs-target="#tabCategories" type="button">
            <i class="bi bi-tag me-1"></i>Kategoriler
            <span class="badge bg-secondary-soft ms-1">@categories.Count()</span>
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(activeTab=="units"?"active":"")"
                data-bs-toggle="tab" data-bs-target="#tabUnits" type="button">
            <i class="bi bi-rulers me-1"></i>Birimler
            <span class="badge bg-secondary-soft ms-1">@units.Count()</span>
        </button>
    </li>
</ul>

<div class="tab-content">

    <!-- ══ KATEGORİLER ══════════════════════════════════════════════════ -->
    <div class="tab-pane fade @(activeTab=="categories"?"show active":"")" id="tabCategories">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Ürün Kategorileri</span>
                <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#catModal"
                        onclick="openCatModal()">
                    <i class="bi bi-plus-lg me-1"></i>Yeni Kategori
                </button>
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th style="width:20px"></th>
                            <th>Ad</th>
                            <th>Açıklama</th>
                            <th class="text-center">Ürün Sayısı</th>
                            <th style="width:80px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in categories)
                        {
                            <tr>
                                <td>
                                    <span style="display:inline-block;width:16px;height:16px;border-radius:4px;background:@(cat.ColorHex ?? "#6b7280")"></span>
                                </td>
                                <td class="fw-semibold">@cat.Name</td>
                                <td class="text-muted" style="font-size:.85rem">@(cat.Description ?? "—")</td>
                                <td class="text-center text-muted" style="font-size:.85rem">@cat.Products.Count()</td>
                                <td>
                                    <div class="d-flex gap-1 justify-content-end">
                                        <button class="btn btn-sm btn-outline-secondary"
                                                onclick="openCatModal(@cat.Id, '@Html.Raw(cat.Name.Replace("'", "\\'"))', '@Html.Raw((cat.Description ?? "").Replace("'", "\\'"))', '@(cat.ColorHex ?? "#6b7280")')">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <form asp-action="DeleteCategory" asp-route-id="@cat.Id" method="post" style="display:inline"
                                              onsubmit="return confirm('@Html.Raw(cat.Name.Replace("'","\\'")) kategorisini silmek istediğinize emin misiniz?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!categories.Any())
                        {
                            <tr><td colspan="5"><div class="empty-state"><i class="bi bi-tag"></i><div>Henüz kategori yok</div></div></td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ══ BİRİMLER ════════════════════════════════════════════════════ -->
    <div class="tab-pane fade @(activeTab=="units"?"show active":"")" id="tabUnits">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Ölçü Birimleri</span>
                <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#unitModal"
                        onclick="openUnitModal()">
                    <i class="bi bi-plus-lg me-1"></i>Yeni Birim
                </button>
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Birim Adı</th>
                            <th>Sembol</th>
                            <th class="text-center">Ürün Sayısı</th>
                            <th style="width:80px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var unit in units)
                        {
                            <tr>
                                <td class="fw-semibold">@unit.Name</td>
                                <td>
                                    <span class="badge bg-secondary-soft" style="font-family:monospace;font-size:.8rem">@unit.Symbol</span>
                                </td>
                                <td class="text-center text-muted" style="font-size:.85rem">@unit.Products.Count()</td>
                                <td>
                                    <div class="d-flex gap-1 justify-content-end">
                                        <button class="btn btn-sm btn-outline-secondary"
                                                onclick="openUnitModal(@unit.Id, '@Html.Raw(unit.Name.Replace("'","\\'"))', '@unit.Symbol')">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <form asp-action="DeleteUnit" asp-route-id="@unit.Id" method="post" style="display:inline"
                                              onsubmit="return confirm('@unit.Symbol birimini silmek istediğinize emin misiniz?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!units.Any())
                        {
                            <tr><td colspan="4"><div class="empty-state"><i class="bi bi-rulers"></i><div>Henüz birim yok</div></div></td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ══ KATEGORİ MODAL ═══════════════════════════════════════════════════ -->
<div class="modal fade" id="catModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="catForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="catModalTitle"><i class="bi bi-tag me-2"></i>Yeni Kategori</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Kategori Adı <span class="text-danger">*</span></label>
                            <input type="text" name="name" id="cat_Name" class="form-control"
                                   placeholder="İçecek Hammaddesi, Ambalaj..." required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Açıklama</label>
                            <input type="text" name="description" id="cat_Desc" class="form-control"
                                   placeholder="Opsiyonel..." />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Renk</label>
                            <div class="d-flex align-items-center gap-3">
                                <input type="color" name="colorHex" id="cat_Color" class="form-control form-control-color"
                                       value="#4f46e5" style="width:56px;height:40px;padding:2px;cursor:pointer" />
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var c in new[]{"#3B82F6","#10B981","#F59E0B","#EF4444","#8B5CF6","#EC4899","#14B8A6","#F97316","#6B7280"})
                                    {
                                        <button type="button" onclick="document.getElementById('cat_Color').value='@c'"
                                                style="width:24px;height:24px;border-radius:50%;background:@c;border:2px solid transparent;cursor:pointer"
                                                title="@c"></button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ══ BİRİM MODAL ══════════════════════════════════════════════════════ -->
<div class="modal fade" id="unitModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form id="unitForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="unitModalTitle"><i class="bi bi-rulers me-2"></i>Yeni Birim</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Birim Adı <span class="text-danger">*</span></label>
                        <input type="text" name="name" id="unit_Name" class="form-control"
                               placeholder="Kilogram, Litre, Adet..." required />
                    </div>
                    <div class="mb-1">
                        <label class="form-label">Sembol <span class="text-danger">*</span></label>
                        <input type="text" name="symbol" id="unit_Symbol" class="form-control"
                               placeholder="kg, lt, ad..." maxlength="10" required />
                        <div class="text-muted mt-1" style="font-size:.78rem">Ürün kartlarında ve raporlarda görünür</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function openCatModal(id, name, desc, color) {
    const form = document.getElementById('catForm');
    if (id) {
        document.getElementById('catModalTitle').innerHTML = '<i class="bi bi-pencil me-2"></i>Kategori Düzenle';
        form.action = '/Definitions/EditCategory/' + id;
    } else {
        document.getElementById('catModalTitle').innerHTML = '<i class="bi bi-tag me-2"></i>Yeni Kategori';
        form.action = '@Url.Action("CreateCategory","Definitions")';
        document.getElementById('cat_Name').value = '';
        document.getElementById('cat_Desc').value = '';
        document.getElementById('cat_Color').value = '#4f46e5';
        return;
    }
    document.getElementById('cat_Name').value = name || '';
    document.getElementById('cat_Desc').value = desc || '';
    document.getElementById('cat_Color').value = color || '#4f46e5';
    new bootstrap.Modal(document.getElementById('catModal')).show();
}

document.getElementById('catModal').addEventListener('hidden.bs.modal', function() {
    document.getElementById('catForm').action = '@Url.Action("CreateCategory","Definitions")';
    document.getElementById('catModalTitle').innerHTML = '<i class="bi bi-tag me-2"></i>Yeni Kategori';
});

function openUnitModal(id, name, symbol) {
    const form = document.getElementById('unitForm');
    if (id) {
        document.getElementById('unitModalTitle').innerHTML = '<i class="bi bi-pencil me-2"></i>Birim Düzenle';
        form.action = '/Definitions/EditUnit/' + id;
        document.getElementById('unit_Name').value = name || '';
        document.getElementById('unit_Symbol').value = symbol || '';
        new bootstrap.Modal(document.getElementById('unitModal')).show();
    } else {
        document.getElementById('unitModalTitle').innerHTML = '<i class="bi bi-rulers me-2"></i>Yeni Birim';
        form.action = '@Url.Action("CreateUnit","Definitions")';
        document.getElementById('unit_Name').value = '';
        document.getElementById('unit_Symbol').value = '';
    }
}

document.getElementById('unitModal').addEventListener('hidden.bs.modal', function() {
    document.getElementById('unitForm').action = '@Url.Action("CreateUnit","Definitions")';
    document.getElementById('unitModalTitle').innerHTML = '<i class="bi bi-rulers me-2"></i>Yeni Birim';
});
</script>
}
