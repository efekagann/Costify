@model Costify.Web.ViewModels.ReportViewModel
@{
    ViewData["Title"] = Localizer["Reports_Title"].Value;
    var maxMonthly = Model.MonthlySpends.Count > 0 ? Model.MonthlySpends.Max(r => r.Amount) : 1;
    string[] months = Localizer["Reports_Months"].Value.Split(',');
}

<!-- KPI Summary -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:linear-gradient(135deg,#4f46e5,#4338ca)">
                <i class="bi bi-cart-check"></i>
            </div>
            <div class="stat-value">@Model.TotalSpend.ToString("N0") ₺</div>
            <div class="stat-label">@Localizer["Reports_TotalPurchases"]</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:linear-gradient(135deg,#10b981,#059669)">
                <i class="bi bi-boxes"></i>
            </div>
            <div class="stat-value">@Model.TotalInventoryValue.ToString("N0") ₺</div>
            <div class="stat-label">@Localizer["Reports_StockValue"]</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:linear-gradient(135deg,#f59e0b,#d97706)">
                <i class="bi bi-clipboard-data"></i>
            </div>
            <div class="stat-value">@Model.RecipeCount</div>
            <div class="stat-label">@Localizer["Reports_ActiveRecipes"]</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:@(Model.AvgFoodCostPct < 25 ? "linear-gradient(135deg,#10b981,#059669)" : Model.AvgFoodCostPct < 35 ? "linear-gradient(135deg,#f59e0b,#d97706)" : "linear-gradient(135deg,#ef4444,#dc2626)")">
                <i class="bi bi-percent"></i>
            </div>
            <div class="stat-value">%@Model.AvgFoodCostPct.ToString("N1")</div>
            <div class="stat-label">@Localizer["Reports_AvgFoodCost"]</div>
        </div>
    </div>
</div>

<!-- Download buttons -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-download me-2"></i>@Localizer["Reports_DownloadExcel"]</span>
        <span class="text-muted small">@Localizer["Reports_ExcelHint"]</span>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="p-3 rounded-3" style="background:#f8fafc;border:1px solid var(--border)">
                    <div class="fw-semibold mb-2"><i class="bi bi-cart-check me-2 text-primary"></i>@Localizer["Reports_PurchaseReport"]</div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Export" asp-route-period="daily"   class="btn btn-outline-primary btn-sm"><i class="bi bi-calendar-day me-1"></i>@Localizer["Reports_Daily"]</a>
                        <a asp-action="Export" asp-route-period="weekly"  class="btn btn-outline-primary btn-sm"><i class="bi bi-calendar-week me-1"></i>@Localizer["Reports_Weekly"]</a>
                        <a asp-action="Export" asp-route-period="monthly" class="btn btn-outline-primary btn-sm"><i class="bi bi-calendar-month me-1"></i>@Localizer["Reports_Monthly"]</a>
                        <a asp-action="Export" asp-route-period="yearly"  class="btn btn-outline-primary btn-sm"><i class="bi bi-calendar-range me-1"></i>@Localizer["Reports_Yearly"]</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 rounded-3" style="background:#f8fafc;border:1px solid var(--border)">
                    <div class="fw-semibold mb-2"><i class="bi bi-boxes me-2 text-success"></i>@Localizer["Reports_StockReport"]</div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="ExportStock" asp-route-period="monthly" class="btn btn-outline-success btn-sm"><i class="bi bi-download me-1"></i>@Localizer["Reports_StockStatus"]</a>
                    </div>
                    <div class="text-muted" style="font-size:.75rem;margin-top:.5rem">@Localizer["Reports_StockHint"]</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 rounded-3" style="background:#f8fafc;border:1px solid var(--border)">
                    <div class="fw-semibold mb-2"><i class="bi bi-clipboard-data me-2 text-warning"></i>@Localizer["Reports_RecipeCostReport"]</div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="ExportRecipes" class="btn btn-outline-warning btn-sm"><i class="bi bi-download me-1"></i>@Localizer["Reports_AllRecipes"]</a>
                    </div>
                    <div class="text-muted" style="font-size:.75rem;margin-top:.5rem">@Localizer["Reports_RecipeHint"]</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Monthly Purchases Chart -->
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">@Localizer["Reports_MonthlyPurchases"]</div>
            <div class="card-body">
                @if (Model.MonthlySpends.Any())
                {
                    <div class="d-flex align-items-end gap-2" style="height:160px">
                        @foreach (var row in Model.MonthlySpends)
                        {
                            var pct = maxMonthly > 0 ? (double)row.Amount / (double)maxMonthly * 100 : 0;
                            <div class="d-flex flex-column align-items-center flex-grow-1">
                                <div class="text-muted text-center mb-1" style="font-size:.7rem">@row.Amount.ToString("N0")₺</div>
                                <div style="width:100%;background:linear-gradient(180deg,#4f46e5,#6366f1);border-radius:6px 6px 0 0;height:@pct.ToString("0")%;min-height:4px;transition:height .3s"></div>
                                <div class="text-muted text-center mt-1" style="font-size:.72rem">@months[row.Month-1]<br/>@(row.Year.ToString().Substring(2))</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state"><i class="bi bi-bar-chart"></i><div>@Localizer["Common_NoData"]</div></div>
                }
            </div>
        </div>
    </div>

    <!-- Vendor Spend -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">@Localizer["Reports_VendorSpend"]</div>
            <div class="card-body">
                @foreach (var v in Model.VendorSpends)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1" style="font-size:.82rem">
                            <span class="fw-medium text-truncate" style="max-width:65%">@v.VendorName</span>
                            <span class="text-muted">@v.Amount.ToString("N0") ₺</span>
                        </div>
                        <div style="height:6px;background:#e2e8f0;border-radius:3px">
                            <div style="width:@v.Percentage.ToString("0")%;height:100%;background:var(--primary);border-radius:3px"></div>
                        </div>
                    </div>
                }
                @if (!Model.VendorSpends.Any()) { <div class="empty-state small"><i class="bi bi-truck"></i><div>@Localizer["Common_NoData"]</div></div> }
            </div>
        </div>
    </div>

    <!-- Stock Value by Category -->
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">@Localizer["Reports_StockByCategory"]</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>@Localizer["Common_Category"]</th>
                            <th class="text-end">@Localizer["Reports_Value"]</th>
                            <th class="text-end">@Localizer["Reports_Share"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sv in Model.StockValues)
                        {
                            <tr>
                                <td><span class="badge me-1" style="background:@sv.ColorHex+'20';color:@sv.ColorHex">●</span>@sv.CategoryName</td>
                                <td class="text-end fw-semibold">@sv.Value.ToString("N2") ₺</td>
                                <td class="text-end text-muted small">%@sv.Percentage.ToString("N1")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td class="fw-bold">@Localizer["Common_Total"]</td>
                            <td class="text-end fw-bold">@Model.TotalInventoryValue.ToString("N2") ₺</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <!-- Recipe Food Cost Analysis -->
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">@Localizer["Reports_RecipeCostAnalysis"]</div>
            <div class="card-body p-0">
                @if (Model.RecipeCosts.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>@Localizer["Recipes_Title"]</th>
                                <th>@Localizer["Common_Category"]</th>
                                <th class="text-end">@Localizer["Reports_Cost"]</th>
                                <th class="text-end">@Localizer["Common_Price"]</th>
                                <th class="text-end">@Localizer["Reports_GMPct"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rc in Model.RecipeCosts.OrderBy(r => r.FoodCostPct))
                            {
                                var (fcColor, fcBg) = rc.FoodCostPct < 25 ? ("#10b981","bg-success-soft")
                                                    : rc.FoodCostPct < 35 ? ("#f59e0b","bg-warning-soft")
                                                    :                        ("#ef4444","bg-danger-soft");
                                <tr>
                                    <td class="fw-medium">@rc.Name</td>
                                    <td class="text-muted small">@rc.Category</td>
                                    <td class="text-end">@rc.Cost.ToString("N2") ₺</td>
                                    <td class="text-end">@rc.SellingPrice.ToString("N2") ₺</td>
                                    <td class="text-end">
                                        <span class="badge @fcBg" style="color:@fcColor">%@rc.FoodCostPct.ToString("N1")</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state"><i class="bi bi-clipboard-data"></i><div>@Localizer["Reports_NoRecipes"]</div></div>
                }
            </div>
        </div>
    </div>
</div>
