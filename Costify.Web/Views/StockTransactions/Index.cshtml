@model Costify.Web.ViewModels.PaginatedList<Costify.Domain.Entities.StockTransaction>
@using Costify.Domain.Enums
@{
    ViewData["Title"] = Localizer["ST_Title"].Value;
    var products = ViewBag.Products as IEnumerable<dynamic> ?? [];

    string TypeLabel(StockTransactionType t) => t switch {
        StockTransactionType.Purchase   => Localizer["Products_Purchase"].Value,
        StockTransactionType.Usage      => Localizer["Products_Usage"].Value,
        StockTransactionType.Adjustment => Localizer["Products_Adjustment"].Value,
        StockTransactionType.Waste      => Localizer["Products_Waste"].Value,
        StockTransactionType.Return     => Localizer["Products_Return"].Value,
        _                               => t.ToString()
    };
    string TypeBadge(StockTransactionType t) => t switch {
        StockTransactionType.Purchase   => "bg-success-soft text-success",
        StockTransactionType.Usage      => "bg-info-soft text-info",
        StockTransactionType.Adjustment => "bg-warning-soft text-warning",
        StockTransactionType.Waste      => "bg-danger-soft text-danger",
        StockTransactionType.Return     => "bg-secondary-soft text-secondary",
        _                               => "bg-secondary-soft"
    };
}

<div class="page-header">
    <div class="text-muted small">
        <i class="bi bi-arrow-left-right me-1"></i>@Model.TotalCount @Localizer["Pagination_Items"]
    </div>
</div>

<!-- Filtreler -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small mb-1">@Localizer["Common_Product"]</label>
                <select name="productId" class="form-select form-select-sm">
                    <option value="">@Localizer["ST_AllProducts"]</option>
                    @foreach (var p in products)
                    {
                        if (ViewBag.ProductId?.ToString() == p.Id.ToString())
                        {
                            <option value="@p.Id" selected>@p.Name</option>
                        }
                        else
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">@Localizer["Products_Type"]</label>
                <select name="type" class="form-select form-select-sm">
                    <option value="">@Localizer["ST_AllTypes"]</option>
                    @foreach (StockTransactionType t in Enum.GetValues<StockTransactionType>())
                    {
                        if (ViewBag.Type?.ToString() == ((int)t).ToString())
                        {
                            <option value="@((int)t)" selected>@TypeLabel(t)</option>
                        }
                        else
                        {
                            <option value="@((int)t)">@TypeLabel(t)</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">@Localizer["PO_FilterFrom"]</label>
                <input type="date" name="from" class="form-control form-control-sm" value="@ViewBag.From" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">@Localizer["PO_FilterTo"]</label>
                <input type="date" name="to" class="form-control form-control-sm" value="@ViewBag.To" />
            </div>
            <div class="col-auto d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-funnel me-1"></i>@Localizer["Common_Search"]
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">@Localizer["Common_Clear"]</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Items.Any())
        {
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>@Localizer["Common_Date"]</th>
                        <th>@Localizer["Common_Product"]</th>
                        <th>@Localizer["Products_Type"]</th>
                        <th class="text-end">@Localizer["Common_Quantity"]</th>
                        <th class="text-end">@Localizer["Products_UnitCost"]</th>
                        <th class="text-end">@Localizer["Reports_Value"]</th>
                        <th>@Localizer["Common_Note"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Items)
                    {
                        <tr>
                            <td class="text-muted small">@t.TransactionDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@t.ProductId"
                                   class="fw-semibold text-decoration-none">@t.Product?.Name</a>
                                <small class="text-muted ms-1">@t.Product?.Unit?.Symbol</small>
                            </td>
                            <td><span class="badge @TypeBadge(t.Type)">@TypeLabel(t.Type)</span></td>
                            <td class="text-end fw-semibold @(t.Quantity >= 0 ? "text-success" : "text-danger")">
                                @(t.Quantity >= 0 ? "+" : "")@t.Quantity.ToString("N4")
                            </td>
                            <td class="text-end text-muted small">
                                @(t.UnitCost > 0 ? t.UnitCost.ToString("N2") + " ₺" : "—")
                            </td>
                            <td class="text-end fw-semibold">
                                @(t.UnitCost > 0 ? (Math.Abs(t.Quantity) * t.UnitCost).ToString("N2") + " ₺" : "—")
                            </td>
                            <td class="text-muted small">
                                @if (t.PurchaseOrder is not null)
                                {
                                    <a asp-controller="PurchaseOrders" asp-action="Details"
                                       asp-route-id="@t.PurchaseOrderId" class="text-decoration-none">
                                        <i class="bi bi-cart me-1"></i>@t.PurchaseOrder.OrderNumber
                                    </a>
                                }
                                else
                                {
                                    @(t.Notes ?? "—")
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <partial name="_Pagination" model="Model" />
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-arrow-left-right"></i>
                <div class="fw-medium">@Localizer["ST_NoTransactions"]</div>
            </div>
        }
    </div>
</div>
