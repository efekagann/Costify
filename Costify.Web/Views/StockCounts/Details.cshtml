@model Costify.Domain.Entities.StockCount
@{
    ViewData["Title"] = "Stok Sayımı — " + Model.CountDate.ToLocalTime().ToString("dd.MM.yyyy");
    var isCompleted = Model.Status == Costify.Domain.Enums.StockCountStatus.Completed;
    var diffItems = Model.Items.Where(i => i.Difference != 0).ToList();
}

<div class="row g-3 mb-3">
    <div class="col-auto">
        @if (isCompleted)
        {
            <span class="badge bg-success-soft fs-6"><i class="bi bi-check-circle-fill me-1"></i>Tamamlandı</span>
        }
        else
        {
            <span class="badge bg-info-soft fs-6"><i class="bi bi-hourglass-split me-1"></i>Devam Ediyor</span>
        }
    </div>
    @if (!string.IsNullOrEmpty(Model.Notes))
    {
        <div class="col-auto d-flex align-items-center">
            <span class="text-muted small"><i class="bi bi-chat-text me-1"></i>@Model.Notes</span>
        </div>
    }
    <div class="col-auto ms-auto d-flex gap-2">
        @if (!isCompleted)
        {
            <form asp-action="Finalize" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('Sayım onaylandığında stoklar güncellenecek ve fark kayıtları oluşturulacak. Onaylıyor musunuz?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-success">
                    <i class="bi bi-check2-circle me-1"></i>Sayımı Onayla & Uygula
                </button>
            </form>
        }
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Geri</a>
    </div>
</div>

@if (diffItems.Any() && !isCompleted)
{
    <div class="alert alert-warning d-flex gap-2 align-items-center rounded-3 mb-3" style="font-size:.875rem">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span><strong>@diffItems.Count ürün</strong> için fark tespit edildi. Onayladığınızda bu ürünlerin stokları düzeltilecek.</span>
    </div>
}

<form asp-action="SaveCounts" asp-route-id="@Model.Id" method="post" id="countForm">
    @Html.AntiForgeryToken()
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Sayım Listesi — @Model.Items.Count ürün</span>
            @if (!isCompleted)
            {
                <button type="submit" class="btn btn-sm btn-primary">
                    <i class="bi bi-save me-1"></i>Değerleri Kaydet
                </button>
            }
        </div>
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ürün</th>
                        <th class="text-center">Birim</th>
                        <th class="text-end">Sistem Stoğu</th>
                        <th class="text-end" style="min-width:130px">Sayılan Miktar</th>
                        <th class="text-end">Fark</th>
                        <th class="text-end">Fark Değeri</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items.OrderBy(i => i.Product?.Name))
                    {
                        var diff = item.Difference;
                        var (diffClass, diffIcon) = diff == 0 ? ("text-muted", "bi-dash")
                                                  : diff > 0 ? ("text-success", "bi-arrow-up")
                                                  :             ("text-danger", "bi-arrow-down");
                        var diffValue = Math.Abs(diff) * (item.Product?.LastPurchasePrice ?? 0);

                        <tr class="@(diff != 0 ? "table-warning" : "")">
                            <td class="fw-medium">@item.Product?.Name</td>
                            <td class="text-center text-muted small">@item.Product?.Unit?.Symbol</td>
                            <td class="text-end text-muted">@item.TheoreticalQuantity.ToString("N4")</td>
                            <td class="text-end">
                                @if (!isCompleted)
                                {
                                    <input type="hidden" name="itemIds" value="@item.Id" />
                                    <input type="number" name="countedQtys" class="form-control form-control-sm text-end"
                                           style="width:120px;margin-left:auto"
                                           step="0.0001" min="0" value="@item.CountedQuantity.ToString("0.0000", System.Globalization.CultureInfo.InvariantCulture)"
                                           oninput="updateDiff(this, @item.TheoreticalQuantity.ToString("0.0000", System.Globalization.CultureInfo.InvariantCulture), @(item.Product?.LastPurchasePrice.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) ?? "0"))" />
                                }
                                else
                                {
                                    <span>@item.CountedQuantity.ToString("N4")</span>
                                }
                            </td>
                            <td class="text-end @diffClass" style="font-size:.85rem">
                                @if (diff != 0)
                                {
                                    <span class="fw-semibold"><i class="bi @diffIcon me-1"></i>@Math.Abs(diff).ToString("N4")</span>
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </td>
                            <td class="text-end @(diff != 0 ? "fw-semibold" : "text-muted")" style="font-size:.85rem">
                                @(diff != 0 ? (diff < 0 ? "-" : "+") + diffValue.ToString("N2") + " ₺" : "—")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</form>
